{
  "name": "",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "fix:property-addresses": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/normalizePropertyAddresses.ts",
    "fix:property-public-coords": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/setPropertyPublicCoordinates.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed:properties-full": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/seedPropertiesFull.ts",
    "seed:listings-projects": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/seedListingsProjects.ts",
    "seed:projects30": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/seedProjects30.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "sync:property-location-content": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/syncPropertyLocationContent.ts",
    "sync:property-project-locations": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm ./scripts/syncPropertyProjectLocations.ts",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@payloadcms/db-postgres": "3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/storage-s3": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "@payos/node": "^2.0.5",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.103.3",
    "@types/leaflet": "^1.9.21",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.8.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "next": "16.2.1",
    "payload": "3.81.0",
    "qrcode": "^1.5.4",
    "qs": "^6.15.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "react-redux": "^9.2.0",
    "rss-parser": "^3.13.0",
    "sharp": "0.34.2",
    "tailwind-scrollbar-hide": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/qs": "^6.15.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.1",
    "jsdom": "28.0.0",
    "postcss": "^8.5.9",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
